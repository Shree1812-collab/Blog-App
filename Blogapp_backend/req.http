###create article(author)
POST http://localhost:4000/author-api/articles
Content-Type: application/json

{
    "author":"698aac84c5fcc458b9ac84ad",
    "title":"test1 article",
    "category":"programming",
    "content":"content of test1 article"

}

###read articles by author
GET http://localhost:4000/author-api/articles/698aac84c5fcc458b9ac84ad

###update article by author
PUT http://localhost:4000/author-api/articles
Content-Type: application/json

{
    "author":"698aac84c5fcc458b9ac84ad",
    "articleId":"698aadb689f3ecb0c8657c59",
    "title":"test2 article",
    "category":"programming in c",
    "content":"content of test2 article"

}

###delete article
PATCH http://localhost:4000/author-api/articles/delete
Content-Type: application/json

{
    "articleId": "698aadb689f3ecb0c8657c59"
}

###logout
GET http://localhost:4000/common-api/logout

###read articles
GET http://localhost:4000/user-api/articles

###comments for article
PUT http://localhost:4000/user-api/articles
Content-Type: application/json

{
    "user":"698aac84c5fcc458b9ac84ad",
    "articleId":"698aadb689f3ecb0c8657c59",
    "comment":"Informative article"
}

###test 
GET http://localhost:4000/test

###change pwd
PUT http://localhost:4000/common-api/change-password
Content-Type: application/json

{
    "email":"shreeja12@gmail.com",
    "currentPassword":"user@1234",
    "newPassword":"user@12"
}

